#!/usr/bin/env bash
# Blocks direct pushes to protected branches.
# Stand-in for GitHub branch protection.
# Bypass (emergencies only): git push --no-verify

set -euo pipefail

PROTECTED_BRANCHES=("master" "main")
remote="$1"

while read -r local_ref local_sha remote_ref remote_sha; do
    branch="${remote_ref#refs/heads/}"

    for protected in "${PROTECTED_BRANCHES[@]}"; do
        if [[ "$branch" == "$protected" ]]; then
            echo ""
            echo "  ✗ Direct push to '$protected' blocked."
            echo ""
            echo "    Open a pull request instead:"
            echo "      git checkout -b <feature-branch>"
            echo "      git push -u origin <feature-branch>"
            echo "      gh pr create"
            echo ""
            echo "    To bypass (emergencies only):"
            echo "      git push --no-verify"
            echo ""
            exit 1
        fi
    done
done

exit 0
